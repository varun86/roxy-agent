{
  "mcpServers": {
    "github": {
      "enabled": true,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      },
      "description": "GitHub MCP server for repository, issue, and pull request workflows."
    },
    "playwright": {
      "enabled": true,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp"
      ],
      "description": "Playwright MCP server for browser automation and page interaction."
    }
  },
  "skills": {
    "example-skill": {
      "enabled": true
    }
  },
  "plugins": {
    "roxy_realtime_tts": {
      "enabled": false,
      "config": {
        "text_lang": "ja",
        "pet_play_url": "http://127.0.0.1:23333/play-tts"
      }
    }
  }
}
